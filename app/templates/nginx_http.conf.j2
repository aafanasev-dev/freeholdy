# HTTP-only config — temporary, used for Let's Encrypt ACME challenge
# Generated by freeholdy. Do not edit manually.

{% for part in parts %}
server {
    listen 80;
    server_name {{ part.subdomain }};

    # ACME HTTP-01: certbot --webroot drops the token under {{ webroot }}; serve it
    # over plain HTTP (this prefix location wins over the redirect below).
    location /.well-known/acme-challenge/ {
        root {{ webroot }};
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

{% endfor %}
